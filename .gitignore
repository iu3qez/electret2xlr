# For PCBs designed using KiCad: https://www.kicad.org/
# Format documentation: https://kicad.org/help/file-formats/

# Temporary files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups
*.kicad_prl
*.sch-bak
*~
*.lck
_autosave-*
*.tmp
*-save.pro
*-save.kicad_pcb
*.kicad_pcb.lck
fp-info-cache
*.log
*netlist.json
*layout.json

# Netlist files (exported from Eeschema)
*.net

# Autorouter files (exported from Pcbnew)
*.dsn
*.ses

build/
.DS_Store

# Local pcb cache
.pcb/

# Superpowers scaffolding/planning artifacts (not part of the board itself)
.superpowers/

# KiCad layout history directories
**/.history/
layout/layout.log
*-drc.rpt
